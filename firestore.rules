rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasActiveCareLink(patientId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(patientId)/careLinks/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(patientId)/careLinks/$(request.auth.uid)).data.status == 'active';
    }

    function canViewDocuments(patientId) {
      return isOwner(patientId) ||
        (hasActiveCareLink(patientId) &&
         get(/databases/$(database)/documents/users/$(patientId)/careLinks/$(request.auth.uid)).data.permissions.viewDocuments == true);
    }

    function canViewMedicines(patientId) {
      return isOwner(patientId) ||
        (hasActiveCareLink(patientId) &&
         get(/databases/$(database)/documents/users/$(patientId)/careLinks/$(request.auth.uid)).data.permissions.viewMedicines == true);
    }

    function canManageMedicines(patientId) {
      return isOwner(patientId) ||
        (hasActiveCareLink(patientId) &&
         get(/databases/$(database)/documents/users/$(patientId)/careLinks/$(request.auth.uid)).data.permissions.manageMedicines == true);
    }

    // User profile and emergency contacts
    match /users/{userId} {
      allow read: if isOwner(userId) || hasActiveCareLink(userId);
      allow write: if isOwner(userId);

      match /documents/{docId} {
        allow read: if canViewDocuments(userId);
        allow write: if isOwner(userId);
      }

      match /medicines/{medId} {
        allow read: if canViewMedicines(userId);
        allow write: if canManageMedicines(userId);
      }

      match /careLinks/{guardianId} {
        allow create, update, delete: if isOwner(userId);
        allow read: if isOwner(userId) || request.auth.uid == guardianId;
      }

      match /auditLogs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) || hasActiveCareLink(userId);
        allow update, delete: if false;
      }
    }

    // Patient creates short-lived invite codes to pair with guardian accounts.
    match /pairingCodes/{code} {
      allow create: if isSignedIn() &&
        request.resource.data.patientId == request.auth.uid &&
        request.resource.data.used == false;

      allow read: if isSignedIn() &&
        resource.data.used == false &&
        request.time < resource.data.expiresAt;

      allow update, delete: if isSignedIn() &&
        resource.data.patientId == request.auth.uid;
    }

    // Guardian requests and patient approval workflow.
    match /pairingRequests/{requestId} {
      allow create: if isSignedIn() &&
        request.resource.data.guardianId == request.auth.uid &&
        request.resource.data.status == 'pending';

      allow read: if isSignedIn() &&
        (resource.data.patientId == request.auth.uid ||
         resource.data.guardianId == request.auth.uid);

      allow update: if isSignedIn() &&
        resource.data.patientId == request.auth.uid &&
        request.resource.data.patientId == resource.data.patientId &&
        request.resource.data.guardianId == resource.data.guardianId &&
        (request.resource.data.status == 'approved' ||
         request.resource.data.status == 'rejected');

      allow delete: if false;
    }

    // Optional future collections scoped by user id
    match /documents/{docId} {
      allow read, write: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    match /medicines/{medId} {
      allow read, write: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    // Block everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
